---
config:
  layout: dagre
---
flowchart TB
    canNav{"目标步骤已解锁?"} -- 否 --> blocked["不可点击 不切换"]
    canNav -- 是 --> same{"目标等于当前步?"}
    same -- 是 --> noop["不切换"]
    same -- 否 --> step9State{"当前或目标涉及第九步?"}
    step9State -- 否 普通步骤 --> submitAndGo["提交当前步数据并切换"]
    step9State -- 是 --> onStep9{"当前在第九步?"}
    onStep9 -- 是 离开九 --> coreDone{"核心采集已完成?"}
    coreDone -- 是 --> submitAndGo
    coreDone -- 否 --> hasData{"有答题数据?"}
    hasData -- 无答题数据 --> submitAndGo
    hasData -- 半途有答题 --> leaveModal["离开确认: 半途提交后退出"]
    onStep9 -- 否 要进入九 --> coreDone2{"核心采集已完成?"}
    coreDone2 -- 是 --> submitAndGo
    coreDone2 -- 否 --> midway{"核心采集未完成且半途有提交?"}
    midway -- 否 首次进入 --> submitAndGo
    midway -- 是 半途离开过 --> reenterModal["再进入确认: 重新核心采集"]
    leaveModal -- 确定 --> leaveOk["确定: 提交第九步并切换"]
    leaveModal -- 取消 --> leaveCancel["取消: 继续做题"]
    reenterModal -- 确定 --> reenterOk["确定: 提交当前步 清除半途记录 重新核心采集"]
    reenterModal -- 取消 --> reenterCancel["取消: 留在当前步"]
    click["点击侧栏目标步骤"]